{
  "name": "backend-starter-kit",
  "version": "1.0.0",
  "description": "Production-ready Express.js backend starter with TypeScript, Docker, MongoDB, Zod, Pino and best practices.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run clean && tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build",
    "docker:down": "docker compose down"
  },
  "keywords": [
    "express",
    "typescript",
    "backend",
    "starter",
    "docker",
    "mongodb",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "envalid": "^8.2.0",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "mongoose": "^9.7.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
